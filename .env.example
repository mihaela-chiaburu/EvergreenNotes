# Example environment variables for EvergreenNotes
# Copy this file to .env and fill in real values.

# SQL Server SA password (must meet SQL Server complexity requirements)
SQL_SA_PASSWORD=your_password_here

# JWT signing secret (use a strong, random value)
JWT_SECRET=your_secret_here

# JWT token expiration in minutes
JWT_EXPIRES_MINUTES=60

# Database name used by the application
DB_NAME=EvergreenNotes
