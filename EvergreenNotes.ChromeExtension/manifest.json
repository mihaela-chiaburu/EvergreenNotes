{
  "manifest_version": 3,
  "name": "EvergreenNotes Capture",
  "description": "Capture content from YouTube, TikTok, Instagram, and articles into EvergreenNotes.",
  "version": "0.1.0",
  "action": {
    "default_title": "Save to EvergreenNotes",
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "activeTab", "tabs", "scripting"],
  "host_permissions": [
    "https://localhost:7010/*",
    "http://localhost:5280/*"
  ]
}
